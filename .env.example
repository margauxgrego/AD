# ============================================================
# KUBE DESIGN — Service Produit Logiciel
# Configuration Supabase (HTML standalone)
# ============================================================
#
# Ce fichier est un modèle. Ne jamais committer de vraies clés.
# Copier ce fichier en .env.local et remplir les valeurs.
#
# UTILISATION DANS L'APP :
#   Ouvrir le panneau ⚙ Supabase (en haut à droite)
#   Coller l'URL et l'Anon Key ci-dessous
#   → La config est sauvegardée dans localStorage (clés seulement)
#
# OU pour un déploiement fixe (ex: GitHub Pages / Vercel) :
#   Remplacer les constantes dans index.html :
#     const SUPABASE_URL_FIXED = "https://xxxx.supabase.co";
#     const SUPABASE_KEY_FIXED = "eyJ...";
#
# ============================================================

# URL du projet Supabase
# Exemple : https://abcdefghijkl.supabase.co
SUPABASE_URL=

# Clé publique anonyme (anon key) — sûre pour le frontend
# Ne JAMAIS utiliser la service_role key ici
SUPABASE_ANON_KEY=

# ============================================================
# TABLES UTILISÉES (créées via supabase-schema.sql)
# ============================================================
# imports          — un enregistrement par fichier importé
# soda_rows        — lignes brutes SODA (optionnel, volumeux)
# kpi_snapshots    — KPIs calculés à chaque import
# sku_stats        — stats par MARKETING_NAME
# anomalies        — anomalies détectées
# import_logs      — journal d'audit
#
# VUES
# v_kpi_history    — historique KPI pour graphiques tendance
# v_stock_tension  — produits en tension (dernier import)
#
# FONCTION RPC
# insert_import_with_kpis — insère import + KPI en transaction
# ============================================================
